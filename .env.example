# Shared password for the site. Humans use the login form; a kiosk can open
# https://your-app.vercel.app/?key=<APP_PASSWORD> to authenticate automatically.
APP_PASSWORD=change-me

# Must match the "Secret token" you set on the GitLab webhook.
GITLAB_WEBHOOK_SECRET=change-me-too

# Injected automatically by the Vercel + Upstash Marketplace integration.
# When absent (local dev), an in-memory store is used instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: overrides the session-cookie signing key.
# Defaults to a hash derived from APP_PASSWORD.
SESSION_SECRET=
